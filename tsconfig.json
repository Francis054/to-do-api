{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src/**/*", "openapi.json"],
  "exclude": ["node_modules", "dist"]
}